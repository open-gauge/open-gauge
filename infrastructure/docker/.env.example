# ---------------------------------------------------------------------------
# Open Gauge — Docker Compose environment
#
# This is the single file to edit when deploying Open Gauge. Every credential
# and URL used by infrastructure/docker/docker-compose.yml lives here.
#
# Rename to `.env` (already the default filename Compose loads) and change the
# values below — especially the passwords and SECRET_KEY — before deploying
# to anything other than a local trial.
# ---------------------------------------------------------------------------

# IP or hostname of the machine running Docker. Used to build the public URLs
# below so the app, docs, MinIO, and generated QR codes point at a reachable
# address instead of localhost.
HOST_IP=192.168.1.100

# --- PostgreSQL (db service) -----------------------------------------------
POSTGRES_USER=opengauge_user
POSTGRES_PASSWORD=opengauge_password
POSTGRES_DB=opengauge_db

# --- API (api service) ------------------------------------------------------
# Change this to a long random value in production (e.g. `openssl rand -hex 32`).
SECRET_KEY=change-this-secret-key-in-production

# Public URL of the frontend, used to build links inside the app — including
# the asset URL encoded into generated QR codes and asset labels. Point this
# at your production domain; it must be reachable by anyone scanning a QR code.
FRONTEND_URL=http://${HOST_IP}:3000

# Allow both localhost and remote clients to call the API.
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://${HOST_IP}:3000"]

# --- MinIO (minio + api services) -------------------------------------------
MINIO_ROOT_USER=opengauge_admin
MINIO_ROOT_PASSWORD=opengauge_password_secret
MINIO_BUCKET=opengauge-files
# URL browsers use to reach MinIO directly (file previews/downloads).
MINIO_PUBLIC_URL=http://${HOST_IP}:9000

# --- Web / Docs (web + docs services) ---------------------------------------
NEXT_PUBLIC_API_URL=http://${HOST_IP}:8000
NEXT_PUBLIC_DOCS_URL=http://${HOST_IP}:3002
