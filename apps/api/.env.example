# Environment for running the API directly (outside Docker Compose).
# When running via `docker compose`, edit infrastructure/docker/.env instead —
# that file is the single source of truth for the containerized deployment
# and this one is only used for local `uvicorn`/`pytest` runs.

SECRET_KEY=change-this-secret-key-in-production
DATABASE_URL=postgresql://opengauge_user:opengauge_password@localhost:5432/opengauge_db
CORS_ORIGINS=["http://localhost:3000"]
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Public URL of the frontend — used to build links inside the app, including
# the asset URL encoded into generated QR codes and asset labels.
FRONTEND_URL=http://localhost:3000

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=opengauge_admin
MINIO_SECRET_KEY=opengauge_password_secret
MINIO_BUCKET=opengauge-files
MINIO_SECURE=false
MINIO_PUBLIC_URL=http://localhost:9000
